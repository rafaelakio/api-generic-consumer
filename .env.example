# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string

# ─── AWS / Secrets Manager ────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test           # LocalStack only – use IAM roles in production
AWS_SECRET_ACCESS_KEY=test       # LocalStack only – use IAM roles in production

# Name of the secret that stores Azure AD credentials
AWS_SECRET_NAME_AZURE=api-consumer/azure-ad

# Name of the secret that stores API client credentials (client-credentials flow)
AWS_SECRET_NAME_API_CREDENTIALS=api-consumer/api-credentials

# LocalStack endpoint:
#   npm run dev (host machine) → http://localhost:4566
#   docker compose            → http://localstack:4566
#   production (real AWS)     → deixe vazio ou remova a linha
LOCALSTACK_ENDPOINT=http://localhost:4566
